{
  "name": "@repo/schema",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./generated/openapi": "./generated/openapi.ts",
    "./auth/user.schema": "./src/auth/user.schema.ts",
    "./billing/billing.schema": "./src/billing/billing.schema.ts",
    "./billing/plan.schema": "./src/billing/plan.schema.ts",
    "./billing/subscription.schema": "./src/billing/subscription.schema.ts",
    "./billing/contact.schema": "./src/billing/contact.schema.ts",
    "./marketing/campaign.schema": "./src/marketing/campaign.schema.ts",
    "./marketing/promotion.schema": "./src/marketing/promotion.schema.ts",
    "./shared/base.schema": "./src/shared/base.schema.ts",
    "./shared/errors.schema": "./src/shared/errors.schema.ts",
    "./shared/metadata.schema": "./src/shared/metadata.schema.ts",
    "./shared/money.schema": "./src/shared/money.schema.ts",
    "./openapi-registry": "./src/openapi-registry.ts"
  },
  "scripts": {
    "dev": "bun run build --watch",
    "build": "bun run generate:openapi && bun run generate:types",
    "generate:openapi": "bun run src/scripts/generate-openapi.ts",
    "generate:types": "bun run src/scripts/generate-types.ts",
    "test": "echo 'Add test script here'",
    "lint": "echo 'Add lint script here'"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "openapi-typescript": "^7.10.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "bun-types": "^1.3.2"
  }
}